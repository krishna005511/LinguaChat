# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/linguachat?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d

# ── Email OTP (Gmail) ──────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password)
# Guide: myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── Cloudinary (free tier — image & voice storage) ────────────────────────────
# Sign up at cloudinary.com, create an unsigned upload preset
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=linguachat_preset

# ── LibreTranslate ─────────────────────────────────────────────────────────────
# Default uses libretranslate.com (free, no key needed for basic use)
# Alternatives if rate limited: https://translate.argosopentech.com
LIBRETRANSLATE_URL=https://libretranslate.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
OTP_EXPIRY_MINUTES=10
